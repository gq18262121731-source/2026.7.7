DETECTOR_MODE=mock
MODEL_PATH=
UAV_MODEL_PATH=
PHONE_MODEL_PATH=
SMOKE_YOLO_CONFIDENCE=0.25
UAV_BLB_MODEL_PATH=
UAV_BLB_MODEL_NAME=uav_blb_disease_yolo
UAV_BLB_MODEL_VERSION=smoke_epoch1_blb_20260623
ENABLE_UAV_BLB_SMOKE=false
UAV_BLB_SMOKE_CONFIDENCE=0.25
DATABASE_PATH=
MAX_UPLOAD_SIZE_MB=15
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp
MOCK_SEED=20260622
MOCK_CLASSES=稻瘟病,纹枯病,稻曲病,稻飞虱,稻纵卷叶螟
DEFAULT_SOURCE_TYPE=manual_upload
SEVERITY_LIGHT_MAX_AREA_RATIO=0.05
SEVERITY_MEDIUM_MAX_AREA_RATIO=0.20
SEVERITY_MANY_DETECTIONS_THRESHOLD=3
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=*
UAV_BLB_EXPERIMENTAL_MODEL_PATH=
UAV_BLB_EXPERIMENTAL_MODEL_NAME=uav_blb_disease_yolo
UAV_BLB_EXPERIMENTAL_MODEL_VERSION=experimental_preview408_epoch5_20260623
ENABLE_UAV_BLB_EXPERIMENTAL=false
UAV_BLB_EXPERIMENTAL_CONFIDENCE=0.25

# Optional phone RiceLeafDiseaseBD experimental route. Experimental only, not formal.
PHONE_EXPERIMENTAL_MODEL_PATH=
PHONE_EXPERIMENTAL_MODEL_NAME=phone_rice_disease_yolo
PHONE_EXPERIMENTAL_MODEL_VERSION=experimental_riceleafdiseasebd_3epoch_20260623
ENABLE_PHONE_EXPERIMENTAL=false
PHONE_EXPERIMENTAL_CONFIDENCE=0.25

# LLM provider mode
# mock: local template fallback
# api: real LLM API
LLM_MODE=api

# Provider name, examples: openai, deepseek, qwen, zhipu, custom_openai_compatible
LLM_PROVIDER=custom_openai_compatible

# API key must be set in local .env, never commit real key
LLM_API_KEY=

# OpenAI-compatible base URL, for example:
# https://api.openai.com/v1
# https://api.deepseek.com
# https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.deepseek.com

# Model name
LLM_MODEL=deepseek-v4-flash

LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2
LLM_ENABLE_JSON_RESPONSE_FORMAT=true

# fallback policy
LLM_ENABLE_MOCK_FALLBACK=true
LLM_PROMPT_VERSION=kg_rag_agent_prompt_v1
